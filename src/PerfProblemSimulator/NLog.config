<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="true"
      internalLogLevel="Info"
      internalLogFile="logs/nlog-internal.log">

  <!-- Define log targets -->
  <targets>
    <!-- Console output for development -->
    <target name="console" xsi:type="Console"
            layout="${longdate}|${level:uppercase=true}|${logger}|${message}${onexception:|${exception:format=tostring}}" />

    <!-- File output for production -->
    <target name="file" xsi:type="File"
            fileName="logs/perfproblemsimulator-${shortdate}.log"
            layout="${longdate}|${level:uppercase=true}|${logger}|${message}${onexception:|${exception:format=tostring}}"
            archiveFileName="logs/perfproblemsimulator-{#}.log"
            archiveNumbering="Date"
            archiveEvery="Day"
            maxArchiveFiles="30" />

    <!-- Error file for errors only -->
    <target name="errorfile" xsi:type="File"
            fileName="logs/perfproblemsimulator-errors-${shortdate}.log"
            layout="${longdate}|${level:uppercase=true}|${logger}|${message}${onexception:|${exception:format=tostring}}"
            archiveFileName="logs/perfproblemsimulator-errors-{#}.log"
            archiveNumbering="Date"
            archiveEvery="Day"
            maxArchiveFiles="30" />
  </targets>

  <!-- Define logging rules -->
  <rules>
    <!-- Log all info and above to console and file -->
    <logger name="*" minlevel="Info" writeTo="console,file" />
    
    <!-- Log errors and above to error file -->
    <logger name="*" minlevel="Error" writeTo="errorfile" />
    
    <!-- Reduce noise from SignalR and System libraries -->
    <logger name="Microsoft.AspNet.SignalR.*" minlevel="Warn" writeTo="console,file" final="true" />
    <logger name="System.*" minlevel="Warn" writeTo="console,file" final="true" />
  </rules>
</nlog>
