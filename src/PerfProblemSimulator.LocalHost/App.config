<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <!-- Application Configuration (same keys as web.config) -->
    <add key="owin:AutomaticAppStartup" value="true" />
    <add key="ProblemSimulator:MetricsCollectionIntervalMs" value="250" />
    <add key="ProblemSimulator:LatencyProbeIntervalMs" value="200" />
    <add key="DisableProblemEndpoints" value="false" />
    <add key="IdleTimeoutMinutes" value="20" />
    <add key="HealthProbeRateMs" value="200" />

    <!-- UI Language: set to an ISO 639-1 code (e.g., "es", "fr", "ja") to auto-translate -->
    <add key="UiLanguage" value="es" />

    <!-- Azure Cognitive Services Translator (required when UiLanguage != "en") -->
    <add key="TranslatorApiKey" value="" />
    <add key="TranslatorEndpoint" value="https://api.cognitive.microsofttranslator.com" />
    <add key="TranslatorRegion" value="eastus" />
  </appSettings>
</configuration>
